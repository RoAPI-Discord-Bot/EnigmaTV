<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/enigma_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/gradient_top_scrim"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_enigma_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:tint="#FFFFFF"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tv_enigma_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_enigma_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF4081"
                android:textSize="14sp"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_enigma_episodes"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_list"
            android:tint="#9C27B0"
            android:focusable="true"/>

        <Button
            android:id="@+id/btn_enigma_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#9C27B0"
            android:text="Next Server"
            android:textColor="#FFFFFF"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Center Controls: Rewind / Play-Pause Toggle / Fast-Forward -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="@drawable/rounded_bg_dark">

        <!-- -5 s (tap) / hold to accelerate -->
        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_rewind"
            android:tint="#FFFFFF"
            android:layout_marginEnd="8dp"
            android:focusable="true"
            android:contentDescription="Rewind 5 seconds"/>

        <!--
            Single play/pause toggle button.
            ExoPlayer's PlayerControlView automatically toggles between
            ic_play_arrow (when paused) and ic_pause (when playing)
            using the exo_play and exo_pause IDs inside this FrameLayout.
            Both start GONE — ExoPlayer sets the correct one VISIBLE on first state update.
        -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <ImageButton
                android:id="@id/exo_play"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_play_arrow"
                android:tint="#FFFFFF"
                android:visibility="visible"
                android:focusable="false"
                android:contentDescription="Play"/>

            <ImageButton
                android:id="@id/exo_pause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_pause"
                android:tint="#FFFFFF"
                android:visibility="gone"
                android:focusable="false"
                android:contentDescription="Pause"/>

            <!--
                This transparent overlay intercepts all clicks/focus on the play/pause area
                and toggles playback. This avoids focus fighting between the two hidden buttons.
            -->
            <View
                android:id="@+id/btn_play_pause_overlay"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:focusable="true"
                android:clickable="true"
                android:contentDescription="Play/Pause"/>
        </FrameLayout>

        <!-- +5 s (tap) / hold to accelerate -->
        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_fast_forward"
            android:tint="#FFFFFF"
            android:focusable="true"
            android:contentDescription="Fast forward 5 seconds"/>
    </LinearLayout>

    <!-- Bottom Bar: seek bar + timestamps -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_scrim"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="16dp"
                app:played_color="#9C27B0"
                app:unplayed_color="#40FFFFFF"
                app:buffered_color="#80FFFFFF"
                app:scrubber_color="#9C27B0"
                android:focusable="true"/>

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <ImageButton
                android:id="@id/exo_subtitle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_cc"
                android:tint="#FFFFFF"
                android:focusable="true"
                android:contentDescription="Captions"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
